{
  "name": "@gamelord/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "GameLord desktop application",
  "main": "./out/main/index.mjs",
  "scripts": {
    "build:native": "cd native && node-gyp rebuild",
    "clean": "node -e \"const fs=require('fs');['out','dist'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}})\"",
    "build": "npm run clean && npm run build:native && electron-vite build",
    "dev": "electron-vite dev --remote-debugging-port=${CDP_PORT:-9222}",
    "start": "electron-vite preview",
    "package": "npm run build && electron-builder --dir",
    "make": "npm run build && electron-builder",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "lint": "oxlint -c ../../oxlint.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@sentry/electron": "^7.13.0",
    "@sentry/react": "^10.53.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@gamelord/ui": "workspace:*",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "agent-react-devtools": "^0.4.0",
    "agentation": "^2.2.1",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "electron": "41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.9.0",
    "lucide-react": "^0.525.0",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^12.3.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-devtools-core": "^7.0.1",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "productName": "GameLord"
}
