{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "desktop",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@gamelord/desktop", "dev"],
      "port": 5173,
      "autoPort": true
